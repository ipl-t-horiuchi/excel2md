# どちらか一方（または両方）を設定。重いファイルは Function URL 推奨（API Gateway は最大約29秒でタイムアウト）

# API Gateway（ステージまで）
# VITE_API_ENDPOINT=https://xxxxxxxxxx.execute-api.ap-northeast-1.amazonaws.com/prod

# Lambda Function URL（末尾スラッシュなし）— 長時間処理向け
# VITE_LAMBDA_FUNCTION_URL=https://xxxxxxxxxxxxxxxxxxxxxxxx.lambda-url.ap-northeast-1.on.aws

VITE_API_ENDPOINT=https://fkp5hm86ra.execute-api.us-east-1.amazonaws.com/prod
VITE_LAMBDA_FUNCTION_URL=https://wlho3mvqirgzxhi5qh6dwdt3k40qytwx.lambda-url.ap-northeast-1.on.aws/
